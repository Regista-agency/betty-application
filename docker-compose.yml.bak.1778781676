services:
  bettyiad:
    build:
      context: .
      dockerfile: Dockerfile
      target: production
    container_name: bettyiad-prod
    restart: always
    environment:
      - GEMINI_API_KEY=${GEMINI_API_KEY}
      - GEMINI_MODEL=${GEMINI_MODEL:-gemini-2.5-flash}
      - GOOGLE_SERVICE_ACCOUNT_PATH=/app/google_service_account.json
      - GOOGLE_SHEET_ID=${GOOGLE_SHEET_ID}
      - GCS_BUCKET=${GCS_BUCKET}
      - AUTH_SECRET=${AUTH_SECRET}
      - AUTH_TRUST_HOST=true
      - BETTY_EMAIL=${BETTY_EMAIL}
      - BETTY_PASSWORD=${BETTY_PASSWORD}
    volumes:
      - ./google_service_account.json:/app/google_service_account.json:ro
    expose:
      - "3000"
    networks:
      - traefik-proxy
    labels:
      - traefik.enable=true
      - traefik.docker.network=root_traefik-proxy
      - traefik.http.routers.bettyiad.rule=Host(`bettyiad.regista-agency.com`)
      - traefik.http.routers.bettyiad.entrypoints=websecure
      - traefik.http.routers.bettyiad.tls=true
      - traefik.http.routers.bettyiad.tls.certresolver=letsencrypt
      - traefik.http.routers.bettyiad.service=bettyiad-svc
      - traefik.http.services.bettyiad-svc.loadbalancer.server.port=3000
      - traefik.http.services.bettyiad-svc.loadbalancer.server.scheme=http
      - traefik.http.routers.bettyiad-http.rule=Host(`bettyiad.regista-agency.com`)
      - traefik.http.routers.bettyiad-http.entrypoints=web
      - traefik.http.routers.bettyiad-http.middlewares=bettyiad-https-redirect
      - traefik.http.middlewares.bettyiad-https-redirect.redirectscheme.scheme=https

networks:
  traefik-proxy:
    external: true
    name: root_traefik-proxy
